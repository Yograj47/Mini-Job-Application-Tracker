generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id          String   @id @default(uuid())
  companyName String
  jobTitle    String
  jobType     JobType
  status      Status
  appliedDate DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum JobType {
  INTERNSHIP
  FULL_TIME
  PART_TIME
}

enum Status {
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
}
